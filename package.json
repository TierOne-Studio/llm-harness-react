{
  "name": "@tierone/llm-harness-react",
  "version": "0.3.0",
  "description": "LLM agent harness for React projects \u2014 guides (skills, instructions) + sensors (review agents). Installs into .ruler/ via a 3-way-merge-aware CLI.",
  "type": "module",
  "bin": {
    "llm-harness-react": "bin/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "lib",
    "template",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:harness": "bash template/.ruler/tests/run-acceptance.sh && bash template/.ruler/tests/simulate-prompts.sh",
    "catalog": "node scripts/build-skill-catalog.mjs",
    "catalog:check": "node scripts/build-skill-catalog.mjs --check",
    "eval": "node eval/routing-eval.mjs && node eval/adherence-eval.mjs",
    "eval:routing": "node eval/routing-eval.mjs",
    "eval:adherence": "node eval/adherence-eval.mjs",
    "eval:mutation": "node scripts/mutation-test.mjs",
    "eval:decay": "node scripts/context-decay.mjs"
  },
  "keywords": [
    "llm",
    "harness",
    "harness-engineering",
    "ai-agent",
    "claude",
    "claude-code",
    "ruler",
    "react",
    "skills",
    "agents"
  ],
  "author": "TierOne Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TierOne-Studio/llm-harness-react.git"
  },
  "bugs": {
    "url": "https://github.com/TierOne-Studio/llm-harness-react/issues"
  },
  "homepage": "https://github.com/TierOne-Studio/llm-harness-react#readme",
  "publishConfig": {
    "access": "public"
  }
}
